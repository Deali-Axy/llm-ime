# llm-ime 配置文件
# 复制此文件为 .env 并按需修改

# GGUF 模型文件路径（默认使用与本仓库同级的 Qwen3-0.6B-GGUF 目录）
# LIME_MODEL_PATH=D:\models\Qwen3-0.6B-IQ4_XS.gguf

# 服务监听端口（默认 5000）
# PORT=5000

# 服务监听地址（RIME 首版建议保持 127.0.0.1）
# HOST=127.0.0.1

# /api/ime/* 的可选本地 Bearer 密钥
# LIME_SHARED_SECRET=change-me

# IME 会话闲置过期时间（毫秒）
# LIME_SESSION_TTL_MS=900000
