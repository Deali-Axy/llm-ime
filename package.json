{
  "name": "llm-ime",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "model:download": "node scripts/download-model.mjs",
    "rime:install": "powershell -ExecutionPolicy Bypass -File scripts/install-rime.ps1",
    "typecheck": "turbo typecheck",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "server": "pnpm --filter @workspace/server start",
    "server:dev": "pnpm --filter @workspace/server dev"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "曦远 (DealiAxy)",
    "url": "https://github.com/Deali-Axy"
  }
}
