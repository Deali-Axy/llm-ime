{
  "name": "llm-ime",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "server": "deno run -A -c apps/server/deno.json apps/server/main.ts",
    "server:check": "deno check -c apps/server/deno.json apps/server/main.ts",
    "server:cache": "deno cache -c apps/server/deno.json --node-modules-dir=auto --allow-scripts=npm:node-llama-cpp apps/server/main.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
